##
# Base environment variables for the Docker containers
# Copy this file to .env and fill in the values
##
HOST_MOUNT=/your/mount/point  # Absolute path to the media drive mount point
HOSTNAME=your-hostname        # Used by Notifiarr

# Secrets
NOTIFIARR_API_KEY=your-notifiarr-api-key

# Authentik SSO
# Generate AUTHENTIK_SECRET_KEY with: openssl rand -base64 60
AUTHENTIK_SECRET_KEY=your-secret-key
AUTHENTIK_POSTGRES_PASSWORD=your-postgres-password
